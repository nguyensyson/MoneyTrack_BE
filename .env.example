# MySQL root password
MYSQL_ROOT_PASSWORD=your_root_password_here

# MySQL database name
MYSQL_DATABASE=moneytrack_db

# Spring datasource credentials (should match MySQL user/password)
SPRING_DATASOURCE_USERNAME=your_db_username_here
SPRING_DATASOURCE_PASSWORD=your_db_password_here

# JWT secret key for token signing
JWT_SECRET=your_jwt_secret_here
